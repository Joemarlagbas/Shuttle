<?php
$conn = new mysqli("localhost", "root", "", "shuttle_db");
$msg = "";
$token = $_GET['token'] ?? '';

if ($token) {
    $stmt = $conn->prepare("SELECT * FROM password_resets WHERE token=? AND used=0 AND expires_at>NOW()");
    $stmt->bind_param("s", $token);
    $stmt->execute();
    $res = $stmt->get_result();
    $reset = $res->fetch_assoc();

    if (!$reset) die("Invalid or expired token.");

    if (isset($_POST['reset'])) {
        $pass = password_hash($_POST['password'], PASSWORD_DEFAULT);
        $conn->query("UPDATE users SET password='$pass' WHERE id=" . $reset['user_id']);
        $conn->query("UPDATE password_resets SET used=1 WHERE id=" . $reset['id']);
        $msg = "Password updated successfully. <a href='login.php'>Login</a>";
    }
} else die("No token provided.");
?>
